 ctx.font = 'italic 400 42px "DM Serif Display", Georgia, serif';
 ctx.textAlign = 'center';
 ctx.fillText('Certificate of Completion', W/2, 148);

 // Divider
 ctx.strokeStyle = 'rgba(196,18,48,0.4)';
 ctx.lineWidth = 1;
 ctx.beginPath();
 ctx.moveTo(120, 165); ctx.lineTo(W-120, 165);
 ctx.stroke();

 // "This certifies that"
 ctx.fillStyle = '#9e9bb5';
 ctx.font = '400 14px DM Sans, sans-serif';
 ctx.textAlign = 'center';
 ctx.fillText('This certifies that', W/2, 200);

 // Name — prefer saved value, fall back to whatever is currently typed in the field
