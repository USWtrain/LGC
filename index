function downloadCert() {
 const canvas = document.getElementById('certCanvas');
 // Sync name from input field in case Save was never clicked
 const inputField = document.getElementById('screener-name');
 if (inputField && inputField.value.trim()) screenerName = inputField.value.trim();
 const safeName = (screenerName || 'USW-Screener').replace(/\s+/g,'_');
 // Call drawCertificate, then wait 600ms for the logo onload to complete, then export
 drawCertificate();
 setTimeout(function() {
 const link = document.createElement('a');
 link.download = 'USW_Certificate_' + safeName + '.png';
 link.href = canvas.toDataURL('image/png');
 document.body.appendChild(link);
 link.click();
 document.body.removeChild(link);
 }, 600);
}

