<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>US Wellness Screener Training Manual</title>
<style>
 @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap');

 :root {
 --usw-red: #C41230;
 --usw-dark: #1a1a2e;
 --usw-mid: #2d2d44;
 --usw-card: #22223a;
 --usw-accent: #e8b4b8;
 --usw-gold: #f0c060;
 --usw-green: #2ecc71;
 --usw-warn: #f39c12;
 --usw-danger: #e74c3c;
 --text-primary: #f0eff4;
 --text-muted: #9e9bb5;
 --border: rgba(255,255,255,0.08);
 --sidebar-w: 280px;
 }

 * { margin:0; padding:0; box-sizing:border-box; }

 body {
 font-family: 'DM Sans', sans-serif;
 background: var(--usw-dark);
 color: var(--text-primary);
 min-height: 100vh;
 display: flex;
 }

 /* ── SIDEBAR ─────────────────────────────────────── */
 #sidebar {
 width: var(--sidebar-w);
 background: var(--usw-mid);
 border-right: 1px solid var(--border);
 display: flex;
 flex-direction: column;
 position: fixed;
 top: 0; left: 0; bottom: 0;
 z-index: 100;
 overflow-y: auto;
 transition: transform .3s ease;
 }

 .sidebar-logo {
 padding: 24px 20px 16px;
 border-bottom: 1px solid var(--border);
 }
 .sidebar-logo .brand {
 font-family: 'DM Serif Display', serif;
 font-size: 18px;
 color: var(--text-primary);
 line-height: 1.2;
 }
 .sidebar-logo .sub {
 font-size: 11px;
 color: var(--text-muted);
 margin-top: 3px;
 text-transform: uppercase;
 letter-spacing: .08em;
 }

 .progress-bar-wrap {
 padding: 14px 20px;
 border-bottom: 1px solid var(--border);
 }
 .progress-label {
 font-size: 11px;
 color: var(--text-muted);
 text-transform: uppercase;
 letter-spacing: .07em;
 margin-bottom: 7px;
 display: flex;
 justify-content: space-between;
 }
 .progress-track {
 height: 4px;
 background: rgba(255,255,255,0.1);
 border-radius: 2px;
 overflow: hidden;
 }
 .progress-fill {
 height: 100%;
 background: var(--usw-red);
 border-radius: 2px;
 transition: width .5s ease;
 width: 0%;
 }

 .nav-section { padding: 10px 0; }
 .nav-section-label {
 font-size: 10px;
 font-weight: 600;
 text-transform: uppercase;
 letter-spacing: .1em;
 color: var(--text-muted);
 padding: 8px 20px 4px;
 }

 .nav-item {
 display: flex;
 align-items: center;
 gap: 10px;
 padding: 9px 20px;
 cursor: pointer;
 font-size: 13px;
 font-weight: 500;
 color: var(--text-muted);
 transition: all .15s;
 border-left: 3px solid transparent;
 text-decoration: none;
 }
 .nav-item:hover { color: var(--text-primary); background: rgba(255,255,255,0.04); }
 .nav-item.active { color: var(--text-primary); border-left-color: var(--usw-red); background: rgba(196,18,48,0.1); }
 .nav-item.done .nav-check { color: var(--usw-green); }
 .nav-num {
 width: 20px; height: 20px;
 border-radius: 50%;
 background: rgba(255,255,255,0.07);
 font-size: 11px; font-weight: 700;
 display: flex; align-items: center; justify-content: center;
 flex-shrink: 0;
 color: var(--text-muted);
 }
 .nav-item.active .nav-num { background: var(--usw-red); color: #fff; }
 .nav-item.done .nav-num { background: rgba(46,204,113,0.2); color: var(--usw-green); }

 .oncall-box {
 margin: auto 16px 16px;
 background: rgba(196,18,48,0.15);
 border: 1px solid rgba(196,18,48,0.3);
 border-radius: 8px;
 padding: 12px 14px;
 }
 .oncall-box .label { font-size: 10px; text-transform: uppercase; letter-spacing: .07em; color: var(--usw-accent); margin-bottom: 4px; }
 .oncall-box .number { font-size: 18px; font-weight: 700; letter-spacing: .03em; color: #fff; }
 .oncall-box .note { font-size: 11px; color: var(--text-muted); margin-top: 4px; }

 /* ── MAIN ─────────────────────────────────────── */
 #main {
 margin-left: var(--sidebar-w);
 flex: 1;
 min-height: 100vh;
 }

 /* ── TOP BAR ─────────────────────────────────────── */
 .topbar {
 background: var(--usw-mid);
 border-bottom: 1px solid var(--border);
 padding: 14px 40px;
 display: flex;
 align-items: center;
 justify-content: space-between;
 position: sticky; top: 0; z-index: 50;
 }
 .topbar-title { font-size: 14px; font-weight: 600; }
 .topbar-meta { font-size: 12px; color: var(--text-muted); }
 .hamburger { display:none; background:none; border:none; cursor:pointer; color:var(--text-primary); font-size:22px; }

 /* ── PAGE ─────────────────────────────────────── */
 .page { display: none; padding: 48px 40px 80px; max-width: 860px; }
 .page.active { display: block; }

 /* ── WELCOME ─────────────────────────────────────── */
 .welcome-hero {
 background: linear-gradient(135deg, var(--usw-red) 0%, #7b0a20 100%);
 border-radius: 16px;
 padding: 48px 48px 40px;
 margin-bottom: 32px;
 position: relative;
 overflow: hidden;
 }
 .welcome-hero::before {
 content: '';
 position: absolute; top: -40px; right: -40px;
 width: 200px; height: 200px;
 border-radius: 50%;
 background: rgba(255,255,255,0.06);
 }
 .welcome-hero h1 {
 font-family: 'DM Serif Display', serif;
 font-size: 36px; line-height: 1.2;
 margin-bottom: 12px;
 }
 .welcome-hero p { font-size: 15px; opacity: .85; max-width: 520px; line-height: 1.6; }
 .welcome-hero .stats {
 display: flex; gap: 32px; margin-top: 28px;
 align-items: flex-end;
 }
 .welcome-hero .stat .val {
 font-family: 'DM Serif Display', serif;
 font-size: 28px; font-weight: 400;
 }
 .welcome-hero .stat .lbl { font-size: 12px; opacity: .7; margin-top: 2px; }

 .name-prompt {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 12px;
 padding: 28px 32px;
 margin-bottom: 28px;
 }
 .name-prompt h3 { font-size: 16px; margin-bottom: 6px; }
 .name-prompt p { font-size: 13px; color: var(--text-muted); margin-bottom: 16px; }
 .name-row { display: flex; gap: 12px; }
 .name-row input {
 flex: 1;
 background: rgba(255,255,255,0.06);
 border: 1px solid var(--border);
 border-radius: 8px;
 padding: 10px 14px;
 font-family: 'DM Sans', sans-serif;
 font-size: 14px;
 color: var(--text-primary);
 outline: none;
 transition: border-color .2s;
 }
 .name-row input:focus { border-color: var(--usw-red); }
 .btn {
 background: var(--usw-red);
 color: #fff;
 border: none;
 border-radius: 8px;
 padding: 10px 20px;
 font-family: 'DM Sans', sans-serif;
 font-size: 14px; font-weight: 600;
 cursor: pointer;
 transition: opacity .2s;
 }
 .btn:hover { opacity: .88; }
 .btn.secondary {
 background: rgba(255,255,255,0.08);
 color: var(--text-primary);
 }
 .btn.secondary:hover { background: rgba(255,255,255,0.13); }
 .btn.ghost {
 background: transparent;
 border: 1px solid var(--border);
 color: var(--text-muted);
 }

 .quick-ref-grid {
 display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
 margin-bottom: 28px;
 }
 .qr-card {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 10px;
 padding: 18px 20px;
 }
 .qr-card .icon { font-size: 22px; margin-bottom: 8px; }
 .qr-card h4 { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
 .qr-card p { font-size: 12px; color: var(--text-muted); line-height: 1.5; }

 /* ── MODULE CONTENT ─────────────────────────────────────── */
 .module-header {
 margin-bottom: 36px;
 }
 .module-tag {
 display: inline-block;
 font-size: 11px; font-weight: 600;
 text-transform: uppercase; letter-spacing: .08em;
 color: var(--usw-accent);
 background: rgba(196,18,48,0.15);
 border: 1px solid rgba(196,18,48,0.25);
 border-radius: 4px;
 padding: 3px 10px;
 margin-bottom: 12px;
 }
 .module-header h2 {
 font-family: 'DM Serif Display', serif;
 font-size: 30px; line-height: 1.25;
 margin-bottom: 10px;
 }
 .module-header .desc { font-size: 14px; color: var(--text-muted); line-height: 1.6; }

 .callout {
 border-radius: 10px;
 padding: 16px 20px;
 margin: 20px 0;
 display: flex;
 gap: 14px;
 align-items: flex-start;
 font-size: 13px;
 line-height: 1.6;
 }
 .callout.warn { background: rgba(243,156,18,0.12); border: 1px solid rgba(243,156,18,0.3); }
 .callout.danger { background: rgba(231,76,60,0.12); border: 1px solid rgba(231,76,60,0.35); }
 .callout.info { background: rgba(52,152,219,0.1); border: 1px solid rgba(52,152,219,0.25); }
 .callout.success { background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.25); }
 .callout-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
 .callout strong { display: block; margin-bottom: 3px; font-size: 13px; }

 .section-title {
 font-size: 13px; font-weight: 700;
 text-transform: uppercase; letter-spacing: .07em;
 color: var(--text-muted);
 margin: 32px 0 14px;
 padding-bottom: 8px;
 border-bottom: 1px solid var(--border);
 }

 h3.sub { font-size: 17px; margin: 24px 0 10px; font-family: 'DM Serif Display', serif; }

 .sop-list {
 list-style: none;
 counter-reset: sop;
 }
 .sop-list li {
 counter-increment: sop;
 display: flex;
 gap: 16px;
 margin-bottom: 16px;
 align-items: flex-start;
 font-size: 14px;
 line-height: 1.6;
 }
 .sop-list li::before {
 content: counter(sop);
 background: var(--usw-red);
 color: #fff;
 width: 26px; height: 26px;
 border-radius: 50%;
 display: flex; align-items: center; justify-content: center;
 font-size: 12px; font-weight: 700;
 flex-shrink: 0; margin-top: 1px;
 }

 .bullet-list {
 list-style: none;
 padding: 0;
 }
 .bullet-list li {
 padding: 6px 0 6px 20px;
 position: relative;
 font-size: 14px;
 line-height: 1.6;
 color: var(--text-primary);
 }
 .bullet-list li::before {
 content: '—';
 position: absolute; left: 0;
 color: var(--usw-red); font-weight: 700;
 }

 .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 16px 0; }
 .info-card {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 10px;
 padding: 18px 20px;
 }
 .info-card .card-title { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 8px; }
 .info-card .card-val { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--usw-red); }
 .info-card p { font-size: 13px; color: var(--text-muted); margin-top: 6px; line-height: 1.5; }

 .ref-table {
 width: 100%;
 border-collapse: collapse;
 font-size: 13px;
 margin: 16px 0;
 }
 .ref-table th {
 background: rgba(255,255,255,0.06);
 padding: 10px 14px;
 text-align: left;
 font-size: 11px; text-transform: uppercase; letter-spacing: .06em;
 color: var(--text-muted);
 border-bottom: 1px solid var(--border);
 }
 .ref-table td {
 padding: 10px 14px;
 border-bottom: 1px solid var(--border);
 line-height: 1.5;
 }
 .ref-table tr:last-child td { border-bottom: none; }
 .tag-normal { color: var(--usw-green); font-weight: 600; }
 .tag-warn { color: var(--usw-gold); font-weight: 600; }
 .tag-danger { color: var(--usw-danger); font-weight: 600; }

 .troubleshoot-row {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 8px;
 padding: 14px 18px;
 margin-bottom: 10px;
 font-size: 13px;
 }
 .troubleshoot-row .err { font-weight: 700; color: var(--usw-gold); font-size: 14px; margin-bottom: 4px; }
 .troubleshoot-row .cause { color: var(--text-muted); margin-bottom: 4px; }
 .troubleshoot-row .fix { color: var(--text-primary); }

 .do-dont { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 16px 0; }
 .do-box, .dont-box {
 border-radius: 10px;
 padding: 16px 18px;
 }
 .do-box {
 background: rgba(46,204,113,0.08);
 border: 1px solid rgba(46,204,113,0.25);
 }
 .do-box h5 { color: var(--usw-green); font-size: 12px; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }
 .dont-box {
 background: rgba(231,76,60,0.08);
 border: 1px solid rgba(231,76,60,0.25);
 }
 .dont-box h5 { color: var(--usw-danger); font-size: 12px; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 10px; }
 .do-box li, .dont-box li {
 font-size: 13px; line-height: 1.6;
 padding: 3px 0;
 list-style: none;
 }

 /* ── NAV BUTTONS ─────────────────────────────────────── */
 .page-nav {
 display: flex; justify-content: space-between; align-items: center;
 margin-top: 48px;
 padding-top: 24px;
 border-top: 1px solid var(--border);
 }

 /* ── QUIZ ─────────────────────────────────────── */
 .quiz-header {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 12px;
 padding: 20px 24px;
 margin-bottom: 24px;
 display: flex;
 align-items: center;
 justify-content: space-between;
 }
 .quiz-header .q-title { font-size: 15px; font-weight: 600; }
 .quiz-header .q-score { font-size: 13px; color: var(--text-muted); }
 .quiz-score-badge {
 background: rgba(196,18,48,0.2);
 border: 1px solid rgba(196,18,48,0.3);
 border-radius: 20px;
 padding: 4px 14px;
 font-size: 13px; font-weight: 600;
 color: var(--usw-accent);
 }

 .question-block {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 12px;
 padding: 22px 24px;
 margin-bottom: 18px;
 transition: border-color .2s;
 }
 .question-block.correct { border-color: rgba(46,204,113,0.5); }
 .question-block.incorrect { border-color: rgba(231,76,60,0.4); }

 .q-text { font-size: 15px; line-height: 1.6; margin-bottom: 16px; font-weight: 500; }
 .q-num { font-size: 11px; text-transform: uppercase; letter-spacing: .07em; color: var(--text-muted); margin-bottom: 6px; }

 .choices { display: flex; flex-direction: column; gap: 10px; }
 .choice-btn {
 background: rgba(255,255,255,0.04);
 border: 1px solid var(--border);
 border-radius: 8px;
 padding: 12px 16px;
 text-align: left;
 cursor: pointer;
 font-family: 'DM Sans', sans-serif;
 font-size: 14px;
 color: var(--text-primary);
 transition: all .15s;
 display: flex; gap: 12px; align-items: flex-start;
 }
 .choice-btn:hover:not(:disabled) { border-color: rgba(196,18,48,0.4); background: rgba(196,18,48,0.07); }
 .choice-btn.selected { border-color: var(--usw-red); background: rgba(196,18,48,0.12); }
 .choice-btn.correct-ans { border-color: var(--usw-green); background: rgba(46,204,113,0.12); }
 .choice-btn.wrong-ans { border-color: var(--usw-danger); background: rgba(231,76,60,0.1); }
 .choice-btn:disabled { cursor: default; }
 .choice-label { font-weight: 700; flex-shrink: 0; color: var(--text-muted); }

 .q-feedback {
 margin-top: 12px;
 padding: 12px 14px;
 border-radius: 8px;
 font-size: 13px;
 line-height: 1.5;
 display: none;
 }
 .q-feedback.show { display: block; }
 .q-feedback.ok { background: rgba(46,204,113,0.1); border: 1px solid rgba(46,204,113,0.3); color: #a5d6a7; }
 .q-feedback.bad { background: rgba(231,76,60,0.1); border: 1px solid rgba(231,76,60,0.3); color: #ef9a9a; }

 .retry-btn {
 margin-top: 12px;
 background: transparent;
 border: 1px solid var(--usw-red);
 border-radius: 6px;
 padding: 7px 16px;
 font-family: 'DM Sans', sans-serif;
 font-size: 13px; color: var(--usw-accent);
 cursor: pointer;
 display: none;
 }
 .retry-btn.show { display: inline-block; }
 .retry-btn:hover { background: rgba(196,18,48,0.1); }

 /* ── CERTIFICATE ─────────────────────────────────────── */
 .cert-gate {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 14px;
 padding: 32px;
 text-align: center;
 margin-top: 32px;
 }
 .cert-gate .lock-icon { font-size: 40px; margin-bottom: 12px; }
 .cert-gate h3 { font-family: 'DM Serif Display', serif; font-size: 22px; margin-bottom: 8px; }
 .cert-gate p { font-size: 13px; color: var(--text-muted); margin-bottom: 18px; line-height: 1.6; }

 #certificate-wrapper { display: none; }
 #certificate-wrapper.show { display: block; }

 .cert-canvas-wrap {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 14px;
 padding: 24px;
 text-align: center;
 margin-top: 24px;
 }
 #certCanvas { max-width: 100%; border-radius: 8px; }

 /* ── OVERALL QUIZ PAGE ─────────────────────────────────────── */
 .overall-progress {
 background: var(--usw-card);
 border: 1px solid var(--border);
 border-radius: 12px;
 padding: 20px 24px;
 margin-bottom: 28px;
 }
 .overall-progress h3 { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
 .overall-progress p { font-size: 13px; color: var(--text-muted); margin-bottom: 14px; }
 .overall-bar {
 height: 8px;
 background: rgba(255,255,255,0.08);
 border-radius: 4px; overflow: hidden;
 margin-bottom: 8px;
 }
 .overall-bar-fill {
 height: 100%;
 background: linear-gradient(90deg, var(--usw-red), #f55);
 border-radius: 4px;
 transition: width .5s ease;
 width: 0%;
 }
 .overall-count { font-size: 12px; color: var(--text-muted); }

 .quiz-set { margin-bottom: 36px; }
 .quiz-set-header {
 font-size: 13px;
 font-weight: 600;
 text-transform: uppercase;
 letter-spacing: .07em;
 color: var(--text-muted);
 padding: 8px 0 10px;
 border-bottom: 1px solid var(--border);
 margin-bottom: 18px;
 display: flex;
 justify-content: space-between;
 align-items: center;
 }
 .quiz-set-score { font-size: 13px; color: var(--text-muted); }
 .quiz-set-score.all-done { color: var(--usw-green); }

 /* ── MOBILE ─────────────────────────────────────── */
 @media (max-width: 768px) {
 #sidebar { transform: translateX(-100%); }
 #sidebar.open { transform: translateX(0); }
 #main { margin-left: 0; }
 .hamburger { display: block; }
 .page { padding: 28px 20px 60px; }
 .two-col, .do-dont, .quick-ref-grid { grid-template-columns: 1fr; }
 .welcome-hero { padding: 28px 24px; }
 .welcome-hero h1 { font-size: 26px; }
 .welcome-hero .stats { gap: 20px; flex-wrap: wrap; }
 .topbar { padding: 12px 20px; }
 .quiz-header { flex-direction: column; align-items: flex-start; gap: 8px; }
 .cert-canvas-wrap { padding: 12px; }
 }

 #overlay {
 display: none;
 position: fixed; inset: 0;
 background: rgba(0,0,0,0.5);
 z-index: 90;
 }
 #overlay.show { display: block; }
</style>
</head>
