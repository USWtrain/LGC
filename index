function drawCertificate() {
 const canvas = document.getElementById('certCanvas');
 if (!canvas) return;
 const ctx = canvas.getContext('2d');
 const W = 800, H = 560;
 ctx.clearRect(0, 0, W, H);

 // Background
 ctx.fillStyle = '#0f0f1a';
 ctx.fillRect(0, 0, W, H);

 // Outer border
 ctx.strokeStyle = '#C41230';
 ctx.lineWidth = 3;
 ctx.strokeRect(16, 16, W-32, H-32);
 ctx.strokeStyle = 'rgba(196,18,48,0.3)';
 ctx.lineWidth = 1;
 ctx.strokeRect(24, 24, W-48, H-48);

 // Corner ornaments
 const corners = [[32,32],[W-32,32],[32,H-32],[W-32,H-32]];
 corners.forEach(([x,y]) => {
 ctx.fillStyle = '#C41230';
 ctx.beginPath();
 ctx.arc(x, y, 5, 0, Math.PI * 2);
 ctx.fill();
 });

 // USW Tag
 ctx.fillStyle = 'rgba(196,18,48,0.15)';
 ctx.fillRect(W/2 - 120, 48, 240, 30);
 ctx.fillStyle = '#C41230';
 ctx.font = '600 11px DM Sans, sans-serif';
 ctx.textAlign = 'center';
 ctx.fillText('US WELLNESS · REQUIRED TRAINING', W/2, 68);

