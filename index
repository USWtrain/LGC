function answer(qId, btn, choice, isCorrect) {
 const block = document.getElementById(qId);
 if (block.classList.contains('correct')) return; // already done

 const allBtns = block.querySelectorAll('.choice-btn');
 allBtns.forEach(b => { b.disabled = true; });

 const fb = document.getElementById(qId + '-fb');
 const retry = document.getElementById(qId + '-retry');

 if (isCorrect) {
 btn.classList.add('correct-ans');
 block.classList.add('correct');
 fb.textContent = '✓ ' + FEEDBACK[qId];
 fb.className = 'q-feedback show ok';
 answered[qId] = true;
 updateScores();
 updateNavDone();
 if (isAllCorrect()) {
 setTimeout(unlockCertificate, 500);
 }
 } else {
 btn.classList.add('wrong-ans');
 // highlight correct
 allBtns.forEach(b => {
 if (b.onclick.toString().includes(',true)')) b.classList.add('correct-ans');
 });
 block.classList.add('incorrect');
 fb.textContent = '✗ ' + WRONG_FB[qId];
 fb.className = 'q-feedback show bad';
 retry.classList.add('show');
 }
}

function retryQuestion(qId) {
 const block = document.getElementById(qId);
 block.classList.remove('correct', 'incorrect');
 const allBtns = block.querySelectorAll('.choice-btn');
 allBtns.forEach(b => {
 b.disabled = false;
 b.classList.remove('correct-ans', 'wrong-ans', 'selected');
 });
 const fb = document.getElementById(qId + '-fb');
 fb.className = 'q-feedback';
 document.getElementById(qId + '-retry').classList.remove('show');
}

