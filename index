 <!-- MODULE 6: COUNSELING -->
 <div class="page" id="page-mod11">
 <div class="module-header">
 <div class="module-tag">Module 11</div>
 <h2>Counseling &amp; Results</h2>
 <div class="desc">How to deliver results effectively, privacy rules, and health education points for each screening value.</div>
 </div>

 <h3 class="sub">Training Video</h3>
 <p style="margin:0 0 12px 0">Watch the full counseling and results walkthrough on YouTube.</p>
 <a href="https://www.youtube.com/watch?v=xv81HPbIVWQ" target="_blank" style="display:inline-flex;align-items:center;gap:10px;background:#FF0000;color:#fff;padding:12px 20px;border-radius:8px;text-decoration:none;font-weight:600;font-size:14px;margin-bottom:24px;">
