 const name = screenerName || (inputField && inputField.value.trim()) || 'Screener Name';
 ctx.fillStyle = '#f0eff4';
 ctx.font = 'italic 400 36px "DM Serif Display", Georgia, serif';
 ctx.textAlign = 'center';
 ctx.fillText(name, W/2, 248);

 // Name underline
 const nameW = ctx.measureText(name).width + 60;
 ctx.strokeStyle = 'rgba(196,18,48,0.5)';
 ctx.lineWidth = 1;
 ctx.beginPath();
 ctx.moveTo(W/2 - nameW/2, 258); ctx.lineTo(W/2 + nameW/2, 258);
 ctx.stroke();

 // Body text
 ctx.fillStyle = '#9e9bb5';
