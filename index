 // set scores
 const sets = { set1:0, set2:0, set3:0, set4:0 };
 Object.keys(answered).forEach(qId => { if (answered[qId]) sets[SET_MAP[qId]]++; });
 ['set1','set2','set3','set4'].forEach(s => {
